<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Base configuration: allow cleartext for Tor bootstrap -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>

    <!-- Domain-specific configurations -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">torproject.org</domain>
        <domain includeSubdomains="true">onion.io</domain>
    </domain-config>

    <!-- Debug overrides (only for debug builds) -->
    <debug-overrides>
        <trust-anchors>
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>
</network-security-config>
