<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================ -->
    <!-- Network Permissions                           -->
    <!-- ============================================ -->
    
    <!-- Full network access (required for VPN) -->
    <uses-permission android:name="android.permission.INTERNET" />
    
    <!-- Network state monitoring (for reconnection logic) -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    
    <!-- WiFi state monitoring -->
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    
    <!-- Network connectivity changes -->
    <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" />
    
    <!-- VPN Service permission (required for VpnService) -->
    <uses-permission android:name="android.permission.BIND_VPN_SERVICE"
        tools:ignore="ProtectedPermissions" />

    <!-- ============================================ -->
    <!-- Foreground Service Permissions              -->
    <!-- ============================================ -->
    
    <!-- Foreground service (keep VPN running) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    
    <!-- Foreground service type for VPN (Android 14+) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE" />
    
    <!-- Special use foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- ============================================ -->
    <!-- Notification Permissions                     -->
    <!-- ============================================ -->
    
    <!-- Post notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ============================================ -->
    <!-- Boot & Power Management                     -->
    <!-- ============================================ -->
    
    <!-- Boot completion (for auto-start) -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    
    <!-- Quick boot (for some devices) -->
    <uses-permission android:name="android.permission.RECEIVE_QUICK_BOOT_POWERON"
        tools:ignore="ProtectedPermissions" />
    
    <!-- Wake lock (maintain connection during sleep) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    
    <!-- Request battery optimization exemption -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- ============================================ -->
    <!-- Optional Features (Future)                  -->
    <!-- ============================================ -->
    
    <!-- Query installed apps (for split tunneling) -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- ============================================ -->
    <!-- Hardware Features                           -->
    <!-- ============================================ -->
    
    <!-- Network features (not required but useful) -->
    <uses-feature
        android:name="android.software.connectionservice"
        android:required="false" />

    <!-- ============================================ -->
    <!-- Application Configuration                   -->
    <!-- ============================================ -->
    <application
        android:name=".NexusVpnApplication"
        android:allowBackup="false"
        android:icon="@drawable/ic_vpn"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_vpn"
        android:supportsRtl="true"
        android:theme="@style/Theme.NexusVpn"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="34">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.NexusVpnService"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="connectedDevice"
            android:exported="false"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- Guardian Project TorService (manages Tor daemon) -->
        <service
            android:name="org.torproject.jni.TorService"
            android:exported="false"
            android:enabled="true" />

        <receiver
            android:name=".receiver.BootReceiver"
            android:enabled="true"
            android:exported="true"
            android:directBootAware="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
